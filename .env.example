# AI Provider Configuration
# Supported values: none | openai | anthropic | google | ollama | openai-compatible
# If not set here, configure via the Settings UI instead.
AI_PROVIDER=

# API key for OpenAI, Anthropic, Google Gemini, or OpenAI-compatible providers
# Not required for Ollama
AI_API_KEY=

# Model name — optional for cloud providers (uses a sensible default if omitted)
# Required for Ollama and openai-compatible
# Examples: gpt-4o-mini | claude-haiku-4-5-20251001 | gemini-2.0-flash | llama3.2
AI_MODEL=

# Base URL — required for Ollama and openai-compatible providers
# Ollama default: http://localhost:11434/v1
AI_BASE_URL=

# Database — leave blank to use SQLite (default, zero config)
# Set to a PostgreSQL connection string to use PostgreSQL instead
# DATABASE_URL=postgresql://user:password@localhost:5432/a11y_logger

# Optional: 64-character hex string for encrypting stored API keys
# Auto-generated and saved to ./data/.secret if not set
# ENCRYPTION_SECRET=
